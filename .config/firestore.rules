rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Verifica se o auth.uid é participante de uma conversa (participants ou profileUid)
    function isConversationMember(conversationId) {
      let conv = get(/databases/$(database)/documents/conversations/$(conversationId));
      return conv.exists() && (
        (conv.data.participants != null && request.auth.uid in conv.data.participants) ||
        (conv.data.profileUid != null && request.auth.uid in conv.data.profileUid)
      );
    }

    // Verifica se o profileId pertence ao usuário autenticado
    function ownsProfile(profileId) {
      // Protege contra docs legados/malformados onde profileId pode estar ausente.
      // Sem esse guard, get(/profiles/$(null)) pode falhar e derrubar a avaliação.
      // Observação: as rules fazem short-circuit em &&, então get() só roda se for string.
      return profileId is string && (
        // Alguns fluxos legados podem usar uid como profileId.
        profileId == request.auth.uid ||
        (
          get(/databases/$(database)/documents/profiles/$(profileId)).exists() &&
          get(/databases/$(database)/documents/profiles/$(profileId)).data.uid == request.auth.uid
        )
      );
    }

    // ============================================
    // PROFILES - Perfis de usuários (multi-perfil)
    // ============================================
    // ✅ Leitura pública permitida para:
    // - Verificar disponibilidade de username no cadastro (antes de autenticar)
    // - Exibir perfis públicos no site/app
    // Escrita requer autenticação e ownership

    match /profiles/{profileId} {
      allow read: if true;  // Leitura pública para verificar username e perfis públicos
      // ✅ CORREÇÃO: Separar regras para create/update e delete
      // Para create/update: usa request.resource.data (dados que serão escritos)
      // Para delete: usa resource.data (dados existentes no documento)
      allow create, update: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;

      // ============================================
      // FCM TOKENS - Subcoleção para push notifications
      // ============================================
      // Apenas o dono do perfil pode ler/escrever tokens.
      // Isso evita vazamento de tokens e escrita indevida em perfis de terceiros.
      match /fcmTokens/{tokenId} {
        // Valida ownership diretamente no doc do perfil pai para evitar falsos negativos
        // (ex.: profileId legados ou UID != profileId)
        allow read, write: if isSignedIn()
          && get(/databases/$(database)/documents/profiles/$(profileId)).data.uid
            == request.auth.uid;
      }
    }

    // ============================================
    // USERS - Dados privados do usuário
    // ============================================

    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);

      // Subcoleções privadas do usuário (ex.: blockedUsers)
      match /{document=**} {
        allow read, write: if isSignedIn() && isOwner(userId);
      }
    }

    // ============================================
    // POSTS - Publicações (expiram após 30 dias)
    // ============================================
    // Fields: authorUid (auth UID), authorProfileId (profile ID)
    // Leitura pública permitida para o site (wegig.com.br)

    match /posts/{postId} {
      allow read: if true;  // Leitura pública para site
      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid;
      // Owner pode atualizar/deletar qualquer campo.
      // Outros autenticados podem atualizar contadores (commentCount, forwardCount)
      // desde que não alterem o authorUid (ownership imutável).
      allow update: if isSignedIn() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.authorUid == resource.data.authorUid
      );
      allow delete: if isSignedIn()
        && resource.data.authorUid == request.auth.uid;

      // ============================================
      // COMMENTS - Subcoleção de comentários
      // ============================================
      // Leitura pública (comentários em posts públicos são públicos)
      // Criação: autenticado e authorUid bate com auth
      // Deleção: autor do comentário OU dono do post
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.authorUid == request.auth.uid;
        allow delete: if isSignedIn() && (
          resource.data.authorUid == request.auth.uid ||
          get(/databases/$(database)/documents/posts/$(postId)).data.authorUid == request.auth.uid
        );
        // Permite update SOMENTE para curtidas (likeCount e likedBy)
        allow update: if isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount', 'likedBy']);
      }
    }

    // ============================================
    // CONVERSATIONS - Multi-perfil
    // ============================================
    // Estrutura esperada:
    // - participants: [uid1, uid2] (auth UIDs)
    // - profileUid: [uid1, uid2] (fallback de owners dos perfis)
    // - participantProfiles: [profileId1, profileId2]

    match /conversations/{conversationId} {
      // Para queries: verifica se o usuário está em participants ou profileUid do documento retornado
      // Para leitura de documento específico: usa isConversationMember
      allow read: if isSignedIn() && (
        // Query support: verifica campos do documento retornado (resource.data)
        (resource.data.participants != null && request.auth.uid in resource.data.participants) ||
        (resource.data.profileUid != null && request.auth.uid in resource.data.profileUid)
      );
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participantProfiles != null;
      allow update, delete: if isSignedIn() && (
        (resource.data.participants != null && request.auth.uid in resource.data.participants) ||
        (resource.data.profileUid != null && request.auth.uid in resource.data.profileUid)
      );

      // ============================================
      // MESSAGES - Subcoleção aninhada
      // ============================================
      // SIMPLIFICADO: Verifica apenas se o usuário é participante da conversa pai
      // usando get() que funciona para operações individuais (não queries)
      match /messages/{messageId} {
        // Helper inline para verificar participação
        function canAccessConversation() {
          let conv = get(/databases/$(database)/documents/conversations/$(conversationId)).data;
          return conv != null && (
            (conv.participants != null && request.auth.uid in conv.participants) ||
            (conv.profileUid != null && request.auth.uid in conv.profileUid)
          );
        }
        
        allow read: if isSignedIn() && canAccessConversation();
        allow create: if isSignedIn()
          && canAccessConversation()
          && request.resource.data.senderId == request.auth.uid;
        
        // Valida se apenas campos permitidos foram alterados
        // Inclui receivedBy e readBy para read receipts em grupos
        function onlyAllowedFieldsChanged() {
          let keys = request.resource.data.diff(resource.data).affectedKeys();
          return keys.hasOnly(['reactions', 'deletedForProfiles', 'status', 'receivedBy', 'readBy']);
        }
        
        // Valida transição do campo `status` (read receipts).
        // - Participantes podem marcar como 'delivered'/'read'.
        // - Evita downgrade: uma mensagem 'read' não pode voltar.
        function validStatusUpdate() {
          let keys = request.resource.data.diff(resource.data).affectedKeys();
          return !keys.hasAny(['status']) || (
            request.resource.data.status in ['delivered', 'read']
            && (resource.data.status != 'read' || request.resource.data.status == 'read')
          );
        }

        // ✅ FIX: Permitir update se:
        // 1. É o remetente da mensagem (pode editar/deletar), OU
        // 2. É participante da conversa e está apenas modificando reactions/deletedForProfiles/status/receivedBy/readBy
        allow update: if isSignedIn() && (
          resource.data.senderId == request.auth.uid ||
          (
            canAccessConversation()
            && onlyAllowedFieldsChanged()
            && validStatusUpdate()
          )
        );
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    // ============================================
    // INTERESTS - Interesses enviados entre perfis
    // ============================================

    match /interests/{interestId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.resource.data.profileUid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.profileUid == request.auth.uid;
    }

    // ============================================
    // NOTIFICATIONS - Notificações push/in-app
    // ============================================
    // SIMPLIFICADO: Apenas verifica recipientUid para leitura
    // O filtro por recipientProfileId é feito client-side para isolamento multi-perfil
    // Isso evita problemas com get() em queries e melhora performance

    match /notifications/{notificationId} {
      // Leitura: apenas verificar recipientUid (Security Rules não suporta bem get() em queries)
      allow read: if isSignedIn() 
        && resource.data.recipientUid == request.auth.uid;
      
      // Create: qualquer usuário autenticado pode criar notificações
      // (Cloud Functions e outros usuários podem enviar notificações)
      allow create: if isSignedIn()
        && request.resource.data.recipientProfileId != null
        && request.resource.data.recipientUid != null;
      
      // Update/Delete: apenas o destinatário pode modificar suas notificações
      allow update, delete: if isSignedIn() 
        && resource.data.recipientUid == request.auth.uid;
    }

    // ============================================
    // BLOCKS - Bloqueios entre PERFIS
    // ============================================
    // Bloqueio é por PERFIL, não por usuário.
    // Campos: blockedByProfileId, blockedProfileId, blockedByUid (opcional), blockedUid (opcional)
    match /blocks/{blockId} {
      // Read:
      // - dono do perfil bloqueador (via blockedByUid) pode consultar seus bloqueios
      // - dono do perfil bloqueado (via blockedUid) pode consultar quem o bloqueou (necessário para filtrar visibilidade)
      // - Alternativamente, verifica ownership do perfil via ownsProfile()
      allow read: if isSignedIn() && (
        // Preferir validação por UID (sem get()) para suportar queries/listeners
        // sem estourar limites de get() em listas grandes.
        (resource.data.blockedByUid != null && resource.data.blockedByUid == request.auth.uid) ||
        (resource.data.blockedUid != null && resource.data.blockedUid == request.auth.uid) ||

        // Fallback para edges legados/malformados.
        // Permite leitura via ownsProfile mesmo se apenas um dos UIDs existir.
        // (Útil para reduzir permission-denied em docs antigos.)
        ownsProfile(resource.data.blockedByProfileId) ||
        ownsProfile(resource.data.blockedProfileId)
      );

      // Write: apenas o dono do perfil bloqueador pode criar/atualizar/remover.
      allow create: if isSignedIn() && (
        request.resource.data.blockedByUid == request.auth.uid ||
        ownsProfile(request.resource.data.blockedByProfileId)
      );

      // Permite o dono do perfil bloqueado atualizar/remover para auto-corrigir edges sem blockedUid.
      allow update, delete: if isSignedIn() && (
        resource.data.blockedByUid == request.auth.uid ||
        ownsProfile(resource.data.blockedByProfileId) ||
        ownsProfile(resource.data.blockedProfileId)
      );
    }

    // ============================================
    // REPORTS - Denúncias de conteúdo/perfis
    // ============================================
    // Usuários podem criar reports e visualizar/consultar seus próprios (para verificar duplicatas e rate limit)
    // O campo 'reportedBy' é um array que contém o UID do usuário que reportou
    // O campo 'reporterUid' é o UID do usuário que criou o report
    // Admins acessam via Admin SDK (bypassa regras)
    match /reports/{reportId} {
      // Create: usuário autenticado pode criar report com seu próprio UID
      allow create: if isSignedIn() 
        && request.resource.data.reporterUid == request.auth.uid
        && (request.resource.data.reportedPostId != null || request.resource.data.reportedProfileId != null)
        && request.resource.data.reason != null
        && request.resource.data.status == 'pending';
      
      // Read (get/list): permite leitura/queries onde o usuário é o reporter
      // Queries DEVEM incluir .where('reporterUid', '==', auth.uid) OU
      // .where('reportedBy', 'array-contains', auth.uid)
      allow read: if isSignedIn() 
        && (resource.data.reporterUid == request.auth.uid 
            || request.auth.uid in resource.data.reportedBy);
      
      // Update/Delete: negado para usuários (apenas admins via Admin SDK)
      allow update, delete: if false;
    }

    // ============================================
    // ADMIN NOTIFICATIONS - Notificações para painel admin
    // ============================================
    // Apenas Cloud Functions podem criar (via Admin SDK)
    // Admins acessam via Admin SDK
    match /adminNotifications/{notificationId} {
      allow read, write: if false; // Apenas Admin SDK
    }

    // ============================================
    // RATE LIMITS - Contadores de rate limiting
    // ============================================
    // Apenas Cloud Functions podem acessar (via Admin SDK)
    match /rateLimits/{limitId} {
      allow read, write: if false; // Apenas Admin SDK
    }

    // ============================================
    // FEEDBACKS - Feedback enviado por usuários
    // ============================================
    // Criação: qualquer usuário autenticado
    // Leitura: qualquer usuário autenticado (admin dashboard)
    // Edição/exclusão: apenas Admin SDK
    match /feedbacks/{feedbackId} {
      allow create, read: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
