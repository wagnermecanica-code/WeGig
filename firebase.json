{
  "firestore": {
    "rules": ".config/firestore.rules",
    "indexes": ".config/firestore.indexes.json"
  },
  "storage": {
    "rules": ".config/storage.rules"
  },
  "functions": {
    "source": ".config/functions",
    "predeploy": ["cd \"$RESOURCE_DIR\" && npm run lint"]
  },
  "hosting": {
    "public": "docs",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/admin/**",
        "destination": "/admin/index.html"
      }
    ],
    "headers": [
      {
        "source": "/admin/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      },
      {
        "source": "/api/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      },
      {
        "source": "/architecture/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      },
      {
        "source": "/audits/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      },
      {
        "source": "/Crashlytics/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      },
      {
        "source": "/reports/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      },
      {
        "source": "/sessions/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      },
      {
        "source": "/setup/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      },
      {
        "source": "/troubleshooting/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      },
      {
        "source": "/legacy/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      },
      {
        "source": "/Old/**",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "to-sem-banda-83e19",
          "appId": "1:278498777601:android:3cb8437111dd6c5f9ebe00",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "to-sem-banda-83e19",
          "appId": "1:278498777601:ios:cdeec8b4da7c657a9ebe00",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/WeGig/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "to-sem-banda-83e19",
          "configurations": {
            "android": "1:278498777601:android:3cb8437111dd6c5f9ebe00",
            "ios": "1:278498777601:ios:cdeec8b4da7c657a9ebe00",
            "web": "1:278498777601:web:8a281dd57bf8dfce9ebe00"
          }
        }
      }
    }
  }
}
